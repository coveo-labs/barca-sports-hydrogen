{
  "catalogId": "https://shop.barca.group/a2ui/commerce/v1/catalog.json",
  "version": "1.0.0",
  "components": [
    {
      "id": "ProductCard",
      "description": "Display an individual product with image, name, price, rating, and color variants. Used for individual product highlights within conversations.",
      "properties": {
        "productId": {
          "type": "string",
          "description": "Unique identifier for the product"
        },
        "name": {
          "type": "string",
          "description": "Product name or title"
        },
        "imageUrl": {
          "type": "string",
          "description": "URL to product image"
        },
        "price": {
          "type": "number",
          "description": "Current price"
        },
        "originalPrice": {
          "type": "number",
          "description": "Original price (if on sale)",
          "optional": true
        },
        "currency": {
          "type": "string",
          "description": "Currency code (USD, CAD, GBP)",
          "default": "USD"
        },
        "rating": {
          "type": "number",
          "description": "Product rating (0-5)",
          "optional": true
        },
        "url": {
          "type": "string",
          "description": "Product detail page URL"
        },
        "colors": {
          "type": "array",
          "description": "Available color variants",
          "optional": true,
          "items": {
            "type": "string"
          }
        },
        "selectedColor": {
          "type": "string",
          "description": "Currently selected color",
          "optional": true
        }
      }
    },
    {
      "id": "ProductCarousel",
      "description": "Horizontal scrolling list of products. Use this for product recommendations, search results, or category browsing within a conversation.",
      "properties": {
        "heading": {
          "type": "string",
          "description": "Preferred title/heading for the carousel",
          "optional": true
        },
        "headline": {
          "type": "string",
          "description": "Legacy title/heading for the carousel. Prefer `heading` for new payloads.",
          "optional": true
        },
        "products": {
          "type": "array",
          "description": "Array of products to display",
          "items": {
            "type": "template",
            "componentId": "ProductCard"
          }
        }
      }
    },
    {
      "id": "ProductResearchCard",
      "description": "Display a product deep-dive with one bound product plus AI-generated summary and feature bullets. Use this for research intent responses.",
      "properties": {
        "ec_product_id": {
          "type": "string",
          "description": "Product identifier used to match the bound item from /items"
        },
        "summary": {
          "type": "string",
          "description": "Short AI-generated product research summary",
          "optional": true
        },
        "bullets": {
          "type": "array",
          "description": "Supporting product research bullets",
          "optional": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    {
      "id": "ComparisonTable",
      "description": "Side-by-side product comparison table with key attributes. Use this when the user requests to compare multiple products.",
      "properties": {
        "heading": {
          "type": "string",
          "description": "Preferred title for the comparison",
          "optional": true
        },
        "headline": {
          "type": "string",
          "description": "Legacy title for the comparison. Prefer `heading` for new payloads.",
          "optional": true
        },
        "products": {
          "type": "array",
          "description": "Products to compare (2-4 recommended)",
          "items": {
            "type": "template",
            "componentId": "ProductCard"
          }
        },
        "attributes": {
          "type": "array",
          "description": "Attribute names to compare",
          "items": {
            "type": "string"
          }
        }
      }
    },
    {
      "id": "ComparisonSummary",
      "description": "Short recommendation or trade-off summary shown after a comparison table.",
      "properties": {
        "text": {
          "type": "string",
          "description": "Comparison summary text"
        }
      }
    },
    {
      "id": "BundleDisplay",
      "description": "Config-driven bundle layout that resolves product slot surfaces via `surfaceRef`.",
      "properties": {
        "title": {
          "type": "string",
          "description": "Optional bundle display title",
          "optional": true
        },
        "bundles": {
          "type": "array",
          "description": "Bundle definitions to render",
          "items": {
            "type": "object",
            "properties": {
              "bundleId": {
                "type": "string",
                "description": "Stable bundle identifier"
              },
              "label": {
                "type": "string",
                "description": "Display label for the bundle"
              },
              "description": {
                "type": "string",
                "description": "Short bundle description"
              },
              "slots": {
                "type": "array",
                "description": "Slot definitions resolved from prior bundle slot surfaces",
                "items": {
                  "type": "object",
                  "properties": {
                    "categoryLabel": {
                      "type": "string",
                      "description": "Display label for the slot category"
                    },
                    "surfaceRef": {
                      "type": "string",
                      "description": "Referenced `bundle-surface-*` surface containing the selected product"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "id": "ConversationAnswer",
      "description": "Complete answer to user's question, wrapping text and other components. This is the top-level container for agent responses.",
      "properties": {
        "children": {
          "type": "array",
          "description": "Child components (Text, ProductCarousel, ComparisonTable, etc.)",
          "items": {
            "type": "component"
          }
        }
      }
    },
    {
      "id": "NextActionsBar",
      "description": "Action buttons for follow-up questions or navigation. Display at the end of agent responses to guide the user's next action.",
      "properties": {
        "actions": {
          "type": "array",
          "description": "Array of action buttons",
          "items": {
            "type": "template",
            "componentId": "Button"
          }
        }
      }
    }
  ],
  "imports": [
    {
      "catalogId": "https://a2ui.ai/v1/basic-catalog.json",
      "components": ["Text", "Button"]
    }
  ]
}
