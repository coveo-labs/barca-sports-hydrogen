{"type": "ACTIVITY_SNAPSHOT", "timestamp": 1774281747537, "messageId": "activity-16736a9236c947fb86c366f4cad7fa42", "activityType": "a2ui-surface", "content": {"operations": [{"beginRendering": {"surfaceId": "product-surface-surfboard-bags", "root": "root-product-surface-surfboard-bags", "catalogId": "coveo-commerce-v1"}}, {"surfaceUpdate": {"surfaceId": "product-surface-surfboard-bags", "components": [{"id": "root-product-surface-surfboard-bags", "component": {"ProductCarousel": {"heading": {"literalString": "Top Surfboard Travel Protection"}, "products": {"componentId": "product-card-product-surface-surfboard-bags", "dataBinding": "/items"}}}}]}}, {"dataModelUpdate": {"surfaceId": "product-surface-surfboard-bags", "contents": [{"key": "items", "valueMap": [{"key": "0", "valueMap": [{"key": "ec_name", "valueString": "Voyager Surfboard Travel Bag - Blue"}, {"key": "ec_brand", "valueString": "Ocean & Earth"}, {"key": "ec_price", "valueNumber": 149.99}, {"key": "ec_promo_price", "valueNumber": 149.99}, {"key": "ec_image", "valueString": "https://cdn.shopify.com/s/files/1/0910/6502/4786/files/609a00e445bf_top_right.webp?v=1766165537"}, {"key": "ec_product_id", "valueString": "gid://shopify/ProductVariant/50677311013138"}, {"key": "ec_description", "valueString": "Introducing the Voyager Surfboard Travel Bag, meticulously designed for surf enthusiasts who love to travel. This travel bag ensures your board remains protected and secure, thanks to its scratch-resistant, waterproof coating and protective liners. Sustainable production techniques care for the environment while providing unmatched durability. Enjoy the convenience of a compact, lightweight design and the assurance of a 2-year material warranty. Features include a storage pocket, ventilation panels, and adjustable padding to accommodate your needs. Perfect for long-distance travel, the Voyager ensures your surfboard's safety and your peace of mind.OEBS_E67A"}, {"key": "ec_category", "valueString": "Surfboard Cases & Bags"}, {"key": "ec_rating", "valueNumber": 3.1}, {"key": "clickUri", "valueString": "/products/oebs_e67a"}, {"key": "resultType", "valueString": "product"}, {"key": "queryPinned", "valueString": "false"}, {"key": "ec_shortdesc", "valueString": "Introducing the Voyager Surfboard Travel Bag, meticulously designed for surf enthusiasts who love to travel. This travel bag ensures your board remains protected and secure, thanks to its scratch-resistant, waterproof coating and protective liners. Sustainable production techniques care for the environment while providing unmatched durability. Enjoy the convenience of a compact, lightweight design and the assurance of a 2-year material warranty. Features include a storage pocket, ventilation panels, and adjustable padding to accommodate your needs. Perfect for long-distance travel, the Voyager ensures your surfboard's safety and your peace of mind.OEBS_E67A"}, {"key": "ec_in_stock", "valueString": "true"}, {"key": "ec_item_group_id", "valueString": "9932666274066"}, {"key": "ec_color", "valueString": "Blue"}, {"key": "permanentid", "valueString": "gid://shopify/ProductVariant/50677311013138"}, {"key": "excerpt", "valueString": "... the Voyager Surfboard Travel Bag, meticulously designed for surf enthusiasts who love to travel. This travel bag ensures your board remains protected and secure, thanks to its scratch- ..."}, {"key": "totalNumberOfChildren", "valueNumber": 1.0}]}, {"key": "1", "valueMap": [{"key": "ec_name", "valueString": "WaveGuard Surfboard Travel Bag - Black"}, {"key": "ec_brand", "valueString": "Creatures of Leisure"}, {"key": "ec_price", "valueNumber": 149.99}, {"key": "ec_promo_price", "valueNumber": 149.99}, {"key": "ec_image", "valueString": "https://cdn.shopify.com/s/files/1/0910/6502/4786/files/a86e3c042ee6_bottom_left_f9718c73-d111-49e3-bb48-72e6e73f9ddb.webp?v=1766165524"}, {"key": "ec_product_id", "valueString": "gid://shopify/ProductVariant/50675961004306"}, {"key": "ec_description", "valueString": "The WaveGuard Surfboard Travel Bag is the ultimate travel companion for surfers seeking top-notch protection and style. Designed for long-distance travel, this bag features impact-resistant, heat-resistant lining and full-length foam padding, ensuring your surfboard remains safe and secure. With the added benefit of UV resistance and recyclable components, the WaveGuard prioritizes both durability and environmental responsibility. Available in black, gray, and blue, each bag includes an adjustable handle, padded shoulder straps, and a convenient storage pocket. Enjoy peace of mind with smooth edges, high stability, mesh ventilation panels, and a 2-year material warranty. Measuring 7'0'' in length and 24 inches in width, and weighing only 2.0 lbs, the WaveGuard Surfboard Travel Bag is built for ease of portability without compromising on protection.COLBS_FA63"}, {"key": "ec_category", "valueString": "Surfboard Cases & Bags"}, {"key": "clickUri", "valueString": "/products/colbs_fa63"}, {"key": "resultType", "valueString": "product"}, {"key": "queryPinned", "valueString": "false"}, {"key": "ec_shortdesc", "valueString": "The WaveGuard Surfboard Travel Bag is the ultimate travel companion for surfers seeking top-notch protection and style. Designed for long-distance travel, this bag features impact-resistant, heat-resistant lining and full-length foam padding, ensuring your surfboard remains safe and secure. With the added benefit of UV resistance and recyclable components, the WaveGuard prioritizes both durability and environmental responsibility. Available in black, gray, and blue, each bag includes an adjustable handle, padded shoulder straps, and a convenient storage pocket. Enjoy peace of mind with smooth edges, high stability, mesh ventilation panels, and a 2-year material warranty. Measuring 7'0'' in length and 24 inches in width, and weighing only 2.0 lbs, the WaveGuard Surfboard Travel Bag is built for ease of portability without compromising on protection.COLBS_FA63"}, {"key": "ec_in_stock", "valueString": "true"}, {"key": "ec_item_group_id", "valueString": "9934430306578"}, {"key": "ec_color", "valueString": "Black"}, {"key": "permanentid", "valueString": "gid://shopify/ProductVariant/50675961004306"}, {"key": "excerpt", "valueString": "The WaveGuard Surfboard Travel Bag is the ultimate travel companion for surfers seeking top-notch protection and style."}, {"key": "totalNumberOfChildren", "valueNumber": 3.0}]}, {"key": "2", "valueMap": [{"key": "ec_name", "valueString": "SurfPro Travel Bag - White"}, {"key": "ec_brand", "valueString": "Ocean & Earth"}, {"key": "ec_price", "valueNumber": 199.99}, {"key": "ec_promo_price", "valueNumber": 199.99}, {"key": "ec_image", "valueString": "https://cdn.shopify.com/s/files/1/0910/6502/4786/files/8b84a16bd4b5_top_left.webp?v=1766165545"}, {"key": "ec_product_id", "valueString": "gid://shopify/ProductVariant/50677312061714"}, {"key": "ec_description", "valueString": "SurfPro Travel BagEmbark on your next adventure with the SurfPro Travel Bag, meticulously designed for adventure enthusiasts. Available in sleek black or white, this bag offers unmatched durability and protection for your gear. Featuring heat-resistant lining and high-density foam padding, the SurfPro Travel Bag safeguards your surfboard from impact during every journey.The adjustable length and width ensure a perfect fit for various board sizes, while the padded shoulder straps and ergonomic handles enhance portability. With recyclable components and breathable materials, this travel bag is environmentally conscious and ensures proper ventilation. Additional storage pockets and ventilation panels provide added convenience, making it ideal for airline travel.Certified ISO and stress-tested for durability, the SurfPro Travel Bag boasts a lifetime zipper warranty, offering long-lasting security for your surfboard. Choose SurfPro and travel with confidence and style.OEBS_7774"}, {"key": "ec_category", "valueString": "Surfboard Cases & Bags"}, {"key": "ec_rating", "valueNumber": 3.3}, {"key": "clickUri", "valueString": "/products/oebs_7774"}, {"key": "resultType", "valueString": "product"}, {"key": "queryPinned", "valueString": "false"}, {"key": "ec_shortdesc", "valueString": "SurfPro Travel BagEmbark on your next adventure with the SurfPro Travel Bag, meticulously designed for adventure enthusiasts. Available in sleek black or white, this bag offers unmatched durability and protection for your gear. Featuring heat-resistant lining and high-density foam padding, the SurfPro Travel Bag safeguards your surfboard from impact during every journey.The adjustable length and width ensure a perfect fit for various board sizes, while the padded shoulder straps and ergonomic handles enhance portability. With recyclable components and breathable materials, this travel bag is environmentally conscious and ensures proper ventilation. Additional storage pockets and ventilation panels provide added convenience, making it ideal for airline travel.Certified ISO and stress-tested for durability, the SurfPro Travel Bag boasts a lifetime zipper warranty, offering long-lasting security for your surfboard. Choose SurfPro and travel with confidence and style.OEBS_7774"}, {"key": "ec_in_stock", "valueString": "true"}, {"key": "ec_item_group_id", "valueString": "9934431453458"}, {"key": "ec_color", "valueString": "White"}, {"key": "permanentid", "valueString": "gid://shopify/ProductVariant/50677312061714"}, {"key": "excerpt", "valueString": "... lining and high-density foam padding, the SurfPro Travel Bag safeguards your surfboard from impact during every journey.The ... Choose SurfPro and travel with confidence and style.OEBS_7774"}, {"key": "totalNumberOfChildren", "valueNumber": 2.0}]}]}]}}]}, "replace": true}
