{"type": "ACTIVITY_SNAPSHOT", "timestamp": 1774281815261, "messageId": "activity-8b2f0d3308e44624a699d459f17257f4", "activityType": "a2ui-surface", "content": {"operations": [{"beginRendering": {"surfaceId": "product-surface-paddleboard-beginners", "root": "root-product-surface-paddleboard-beginners", "catalogId": "coveo-commerce-v1"}}, {"surfaceUpdate": {"surfaceId": "product-surface-paddleboard-beginners", "components": [{"id": "root-product-surface-paddleboard-beginners", "component": {"ProductCarousel": {"heading": {"literalString": "Paddleboarding Starter Boards"}, "products": {"componentId": "product-card-product-surface-paddleboard-beginners", "dataBinding": "/items"}}}}]}}, {"dataModelUpdate": {"surfaceId": "product-surface-paddleboard-beginners", "contents": [{"key": "items", "valueMap": [{"key": "0", "valueMap": [{"key": "ec_name", "valueString": "Wave Rider - Blue"}, {"key": "ec_brand", "valueString": "iROCKER"}, {"key": "ec_price", "valueNumber": 299.99}, {"key": "ec_promo_price", "valueNumber": 299.99}, {"key": "ec_image", "valueString": "https://cdn.shopify.com/s/files/1/0910/6502/4786/files/8acd03b05b6a_top_left.webp?v=1766165703"}, {"key": "ec_product_id", "valueString": "gid://shopify/ProductVariant/50677338210578"}, {"key": "ec_description", "valueString": "Embark on your paddling adventure with the Wave Rider, perfect for beginners and young enthusiasts. This versatile 9 ft kids' inflatable stand-up paddleboard offers a stable and fun experience on the water with its blue, UV-resistant PVC material. Featuring a planing hull, non-slip deck pad, and comfortable handle, the Wave Rider ensures a secure and enjoyable ride. Portability is a breeze with its inflatable design and quick 7-minute inflation time using the included hand pump. Certified for durability and sustainable production, it also boasts a leash attachment for added safety, a single fin system, and accessories like a repair kit. Whether you're exploring lakes, rivers, or the ocean, the Wave Rider stands ready for recreational paddling fun, backed by a 1-year limited warranty.IRPDLI_8220"}, {"key": "ec_category", "valueString": "Paddleboards"}, {"key": "clickUri", "valueString": "/products/irpdli_8220"}, {"key": "resultType", "valueString": "product"}, {"key": "queryPinned", "valueString": "false"}, {"key": "ec_shortdesc", "valueString": "Embark on your paddling adventure with the Wave Rider, perfect for beginners and young enthusiasts. This versatile 9 ft kids' inflatable stand-up paddleboard offers a stable and fun experience on the water with its blue, UV-resistant PVC material. Featuring a planing hull, non-slip deck pad, and comfortable handle, the Wave Rider ensures a secure and enjoyable ride. Portability is a breeze with its inflatable design and quick 7-minute inflation time using the included hand pump. Certified for durability and sustainable production, it also boasts a leash attachment for added safety, a single fin system, and accessories like a repair kit. Whether you're exploring lakes, rivers, or the ocean, the Wave Rider stands ready for recreational paddling fun, backed by a 1-year limited warranty.IRPDLI_8220"}, {"key": "ec_in_stock", "valueString": "true"}, {"key": "ec_item_group_id", "valueString": "9932686655762"}, {"key": "ec_color", "valueString": "Blue"}, {"key": "permanentid", "valueString": "gid://shopify/ProductVariant/50677338210578"}, {"key": "excerpt", "valueString": "... 9 ft kids' inflatable stand-up paddleboard offers a stable and fun experience on the ... boasts a leash attachment for added safety, a single fin system, and accessories like a repair kit."}, {"key": "totalNumberOfChildren", "valueNumber": 1.0}]}, {"key": "1", "valueMap": [{"key": "ec_name", "valueString": "FishMaster SUP - White"}, {"key": "ec_brand", "valueString": "BOTE"}, {"key": "ec_price", "valueNumber": 599.99}, {"key": "ec_promo_price", "valueNumber": 599.99}, {"key": "ec_image", "valueString": "https://cdn.shopify.com/s/files/1/0910/6502/4786/files/2f1f248b40f3_bottom_left_5a2f305c-145c-4c55-83c3-ffefc671ab53.webp?v=1766165668"}, {"key": "ec_product_id", "valueString": "gid://shopify/ProductVariant/50675997344018"}, {"key": "ec_description", "valueString": "Discover the joy of paddle boarding and fishing combined with the FishMaster SUP. Designed specifically for beginners, this 11 ft paddleboard boasts a durable fiberglass construction, and is available in eye-catching white and yellow variants. The displacement hull type ensures smooth navigation, while the textured surface and kick pad offer a comfortable and stable deck for all your fishing adventures. Equipped with a quick-lock fin system, safety valve, and eco-friendly materials, this SUP is as safe and sustainable as it is fun. With an impact-resistant build, it can withstand the rigors of the water, and its easy portability means you can take it anywhere. The FishMaster SUP comes with all necessary accessories, including a paddle, fins, and a repair kit. Enjoy a hassle-free experience backed by a 3-year performance warranty. Cast your line and embrace the tranquility of the waters with FishMaster SUP!BTPDLS_4E31"}, {"key": "ec_category", "valueString": "Paddleboards"}, {"key": "clickUri", "valueString": "/products/btpdls_4e31"}, {"key": "resultType", "valueString": "product"}, {"key": "queryPinned", "valueString": "false"}, {"key": "ec_shortdesc", "valueString": "Discover the joy of paddle boarding and fishing combined with the FishMaster SUP. Designed specifically for beginners, this 11 ft paddleboard boasts a durable fiberglass construction, and is available in eye-catching white and yellow variants. The displacement hull type ensures smooth navigation, while the textured surface and kick pad offer a comfortable and stable deck for all your fishing adventures. Equipped with a quick-lock fin system, safety valve, and eco-friendly materials, this SUP is as safe and sustainable as it is fun. With an impact-resistant build, it can withstand the rigors of the water, and its easy portability means you can take it anywhere. The FishMaster SUP comes with all necessary accessories, including a paddle, fins, and a repair kit. Enjoy a hassle-free experience backed by a 3-year performance warranty. Cast your line and embrace the tranquility of the waters with FishMaster SUP!BTPDLS_4E31"}, {"key": "ec_in_stock", "valueString": "true"}, {"key": "ec_item_group_id", "valueString": "9934439612690"}, {"key": "ec_color", "valueString": "White"}, {"key": "permanentid", "valueString": "gid://shopify/ProductVariant/50675997344018"}, {"key": "excerpt", "valueString": "Designed specifically for beginners, this 11 ft paddleboard boasts a durable fiberglass construction, and ... comes with all necessary accessories, including a paddle, fins, and a repair kit."}, {"key": "totalNumberOfChildren", "valueNumber": 2.0}]}]}]}}]}, "replace": true}
