{"type": "ACTIVITY_SNAPSHOT", "timestamp": 1773875931497, "messageId": "activity-89b83b39a9d049cea7d173d622e5ff7d", "activityType": "a2ui-surface", "content": {"operations": [{"beginRendering": {"surfaceId": "product-surface-kayaks", "root": "root-product-surface-kayaks", "catalogId": "coveo-commerce-v1"}}, {"surfaceUpdate": {"surfaceId": "product-surface-kayaks", "components": [{"id": "root-product-surface-kayaks", "component": {"ProductCarousel": {"heading": {"literalString": "Kayaks for Every Adventure"}, "products": {"componentId": "product-card-product-surface-kayaks", "dataBinding": "/items"}}}}]}}, {"dataModelUpdate": {"surfaceId": "product-surface-kayaks", "contents": [{"key": "items", "valueMap": [{"key": "0", "valueMap": [{"key": "ec_name", "valueString": "AeroFit Kayak - Yellow"}, {"key": "ec_brand", "valueString": "Think Kayaks"}, {"key": "ec_price", "valueNumber": 2499.99}, {"key": "ec_promo_price", "valueNumber": 2499.99}, {"key": "ec_image", "valueString": "https://cdn.shopify.com/s/files/1/0910/6502/4786/files/5b284698c6e0_top_left.webp?v=1766164977"}, {"key": "ec_product_id", "valueString": "gid://shopify/ProductVariant/50677277458706"}, {"key": "ec_description", "valueString": "Experience unmatched performance with the AeroFit Kayak, designed for intermediate kayakers looking to elevate their athletic training. Constructed from durable, long-lasting composite materials, this fitness kayak boasts a lightweight build, aerodynamic hull, and adaptable stability, ensuring a smooth and fast ride on the water. Available in vibrant blue or yellow, the AeroFit Kayak features ergonomic footrests, carry handles, and an anti-slip seat for enhanced comfort and safety. Certified by ISO and marine safety standards, this 17 ft kayak with adjustable solo seating is not only portable but also environmentally friendly, being fully recyclable. Enjoy peace of mind with a 5-year structural warranty as you push your limits with the AeroFit Kayak.TKKP_DF84"}, {"key": "ec_category", "valueString": "Slalom Kayaks"}, {"key": "ec_rating", "valueNumber": 3.0}, {"key": "clickUri", "valueString": "/products/tkkp_df84"}, {"key": "resultType", "valueString": "product"}, {"key": "queryPinned", "valueString": "false"}, {"key": "ec_shortdesc", "valueString": "Experience unmatched performance with the AeroFit Kayak, designed for intermediate kayakers looking to elevate their athletic training. Constructed from durable, long-lasting composite materials, this fitness kayak boasts a lightweight build, aerodynamic hull, and adaptable stability, ensuring a smooth and fast ride on the water. Available in vibrant blue or yellow, the AeroFit Kayak features ergonomic footrests, carry handles, and an anti-slip seat for enhanced comfort and safety. Certified by ISO and marine safety standards, this 17 ft kayak with adjustable solo seating is not only portable but also environmentally friendly, being fully recyclable. Enjoy peace of mind with a 5-year structural warranty as you push your limits with the AeroFit Kayak.TKKP_DF84"}, {"key": "ec_in_stock", "valueString": "true"}, {"key": "ec_item_group_id", "valueString": "9934400586002"}, {"key": "ec_color", "valueString": "Yellow"}, {"key": "permanentid", "valueString": "gid://shopify/ProductVariant/50677277458706"}, {"key": "excerpt", "valueString": "Experience unmatched performance with the AeroFit Kayak, designed for intermediate kayakers looking to elevate their athletic training."}, {"key": "totalNumberOfChildren", "valueNumber": 2.0}]}, {"key": "1", "valueMap": [{"key": "ec_name", "valueString": "Adventure XT Kayak - Red"}, {"key": "ec_brand", "valueString": "Epic Kayaks"}, {"key": "ec_price", "valueNumber": 1999.99}, {"key": "ec_promo_price", "valueNumber": 1999.99}, {"key": "ec_image", "valueString": "https://cdn.shopify.com/s/files/1/0910/6502/4786/files/84eb0ea3829d_bottom_left.webp?v=1766164987"}, {"key": "ec_product_id", "valueString": "gid://shopify/ProductVariant/50675200590098"}, {"key": "ec_description", "valueString": "Experience the ultimate in adventure paddling with the Adventure XT Kayak. Designed for the thrill-seeking solo kayaker, this performance touring kayak is crafted from durable Thermoformed ABS and comes in striking red and orange variants. At 17 ft in length and 26 inches wide, it features a streamlined design for racing speeds while maintaining high stability for balance. Engineered for adventure enthusiasts, it includes reinforced hull safety features, shoulder carry straps for easy portability, and sustainable components. Each kayak is ISO certified, marine safety rated, and comes with carry handles and a repair kit for your convenience. Enjoy the peace of mind offered by a 2-year material warranty. Adventure awaits with the Adventure XT Kayak!EPKP_3B58"}, {"key": "ec_category", "valueString": "Slalom Kayaks"}, {"key": "clickUri", "valueString": "/products/epkp_3b58"}, {"key": "resultType", "valueString": "product"}, {"key": "queryPinned", "valueString": "false"}, {"key": "ec_shortdesc", "valueString": "Experience the ultimate in adventure paddling with the Adventure XT Kayak. Designed for the thrill-seeking solo kayaker, this performance touring kayak is crafted from durable Thermoformed ABS and comes in striking red and orange variants. At 17 ft in length and 26 inches wide, it features a streamlined design for racing speeds while maintaining high stability for balance. Engineered for adventure enthusiasts, it includes reinforced hull safety features, shoulder carry straps for easy portability, and sustainable components. Each kayak is ISO certified, marine safety rated, and comes with carry handles and a repair kit for your convenience. Enjoy the peace of mind offered by a 2-year material warranty. Adventure awaits with the Adventure XT Kayak!EPKP_3B58"}, {"key": "ec_in_stock", "valueString": "true"}, {"key": "ec_item_group_id", "valueString": "9934401503506"}, {"key": "ec_color", "valueString": "Red"}, {"key": "permanentid", "valueString": "gid://shopify/ProductVariant/50675200590098"}, {"key": "excerpt", "valueString": "Experience the ultimate in adventure paddling with the Adventure XT Kayak. Designed for the thrill-seeking solo kayaker, this performance touring kayak is crafted from durable Thermoformed ..."}, {"key": "totalNumberOfChildren", "valueNumber": 2.0}]}, {"key": "2", "valueMap": [{"key": "ec_name", "valueString": "HydraFold Kayak - Gray"}, {"key": "ec_brand", "valueString": "Aqua Marina"}, {"key": "ec_price", "valueNumber": 1500.0}, {"key": "ec_promo_price", "valueNumber": 1500.0}, {"key": "ec_image", "valueString": "https://cdn.shopify.com/s/files/1/0910/6502/4786/files/1c1c60212150_bottom_right.webp?v=1766165016"}, {"key": "ec_product_id", "valueString": "gid://shopify/ProductVariant/50677279654162"}, {"key": "ec_description", "valueString": "Experience the ultimate in kayaking performance with the HydraFold Kayak. Designed for enthusiasts who demand high stability and maximum load capacity, this foldable kayak is constructed with a marine-grade aluminum frame for durability and strength. With an easy assembly time of just ~20 minutes, you can quickly transform from compact storage (30 inches x 13 inches x 27 inches) to full size (12 ft x 25 inches). Certified by the US Coast Guard and ISO, it ensures top safety and reliability. Perfect for heavy water conditions, this kayak can comfortably seat two persons and supports up to 400 lbs. Available in sleek black and gray variants, it includes a repair kit and storage bag, and features split paddle compatibility for easy transport. Enjoy peace of mind with a 3-year extended warranty. Paddle with confidence on your next adventure with the HydraFold Kayak.AMKF_52C7"}, {"key": "ec_category", "valueString": "Folding Kayaks"}, {"key": "ec_rating", "valueNumber": 4.4}, {"key": "clickUri", "valueString": "/products/amkf_52c7"}, {"key": "resultType", "valueString": "product"}, {"key": "queryPinned", "valueString": "false"}, {"key": "ec_shortdesc", "valueString": "Experience the ultimate in kayaking performance with the HydraFold Kayak. Designed for enthusiasts who demand high stability and maximum load capacity, this foldable kayak is constructed with a marine-grade aluminum frame for durability and strength. With an easy assembly time of just ~20 minutes, you can quickly transform from compact storage (30 inches x 13 inches x 27 inches) to full size (12 ft x 25 inches). Certified by the US Coast Guard and ISO, it ensures top safety and reliability. Perfect for heavy water conditions, this kayak can comfortably seat two persons and supports up to 400 lbs. Available in sleek black and gray variants, it includes a repair kit and storage bag, and features split paddle compatibility for easy transport. Enjoy peace of mind with a 3-year extended warranty. Paddle with confidence on your next adventure with the HydraFold Kayak.AMKF_52C7"}, {"key": "ec_in_stock", "valueString": "true"}, {"key": "ec_item_group_id", "valueString": "9934403043602"}, {"key": "ec_color", "valueString": "Gray"}, {"key": "permanentid", "valueString": "gid://shopify/ProductVariant/50677279654162"}, {"key": "excerpt", "valueString": "Experience the ultimate in kayaking performance with the HydraFold Kayak. ... high stability and maximum load capacity, this foldable kayak is constructed with a marine-grade aluminum frame ..."}, {"key": "totalNumberOfChildren", "valueNumber": 2.0}]}, {"key": "3", "valueMap": [{"key": "ec_name", "valueString": "Enduro Touring Kayak - Orange"}, {"key": "ec_brand", "valueString": "Necky Kayaks"}, {"key": "ec_price", "valueNumber": 1699.0}, {"key": "ec_promo_price", "valueNumber": 1699.0}, {"key": "ec_image", "valueString": "https://cdn.shopify.com/s/files/1/0910/6502/4786/files/4a8332fec1b6_top_right.webp?v=1766165120"}, {"key": "ec_product_id", "valueString": "gid://shopify/ProductVariant/50677286600978"}, {"key": "ec_description", "valueString": "Embark on extended kayaking adventures with the Enduro Touring Kayak, designed specifically for advanced kayakers. At 450 cm in length, this tandem kayak comfortably accommodates two paddlers and offers exceptional stability for endurance paddling on bays. Built from high-density polypropylene, it boasts superior durability and a UV-resistant finish, ensuring it can withstand diverse conditions. The kayak comes equipped with adjustable seats and a spray skirt, and features convenient deck handles for easy transport. With compatibility for feathered paddles and a swift assembly time of just 12 minutes, the Enduro Touring Kayak combines performance with practicality. Rated for a maximum load capacity of 450 lbs and backed by a lifetime hull warranty, it's the perfect choice for those seeking a premium, reliable kayaking experience. Available in striking blue or vibrant orange to match your adventurous spirit.NKKO_52B8"}, {"key": "ec_category", "valueString": "Flatwater Kayaks"}, {"key": "ec_rating", "valueNumber": 4.0}, {"key": "clickUri", "valueString": "/products/nkko_52b8"}, {"key": "resultType", "valueString": "product"}, {"key": "queryPinned", "valueString": "false"}, {"key": "ec_shortdesc", "valueString": "Embark on extended kayaking adventures with the Enduro Touring Kayak, designed specifically for advanced kayakers. At 450 cm in length, this tandem kayak comfortably accommodates two paddlers and offers exceptional stability for endurance paddling on bays. Built from high-density polypropylene, it boasts superior durability and a UV-resistant finish, ensuring it can withstand diverse conditions. The kayak comes equipped with adjustable seats and a spray skirt, and features convenient deck handles for easy transport. With compatibility for feathered paddles and a swift assembly time of just 12 minutes, the Enduro Touring Kayak combines performance with practicality. Rated for a maximum load capacity of 450 lbs and backed by a lifetime hull warranty, it's the perfect choice for those seeking a premium, reliable kayaking experience. Available in striking blue or vibrant orange to match your adventurous spirit.NKKO_52B8"}, {"key": "ec_in_stock", "valueString": "true"}, {"key": "ec_item_group_id", "valueString": "9934409335058"}, {"key": "ec_color", "valueString": "Orange"}, {"key": "permanentid", "valueString": "gid://shopify/ProductVariant/50677286600978"}, {"key": "excerpt", "valueString": "Embark on extended kayaking adventures with the Enduro Touring Kayak, designed specifically for advanced kayakers."}, {"key": "totalNumberOfChildren", "valueNumber": 2.0}]}, {"key": "4", "valueMap": [{"key": "ec_name", "valueString": "Sprint Racer Kayak - Blue"}, {"key": "ec_brand", "valueString": "Think Kayaks"}, {"key": "ec_price", "valueNumber": 3499.99}, {"key": "ec_promo_price", "valueNumber": 3499.99}, {"key": "ec_image", "valueString": "https://cdn.shopify.com/s/files/1/0910/6502/4786/files/73da0f952841_top_right_cc750d06-d7ec-4abc-a60b-f5d57eae983f.webp?v=1766164983"}, {"key": "ec_product_id", "valueString": "gid://shopify/ProductVariant/50675199082770"}, {"key": "ec_description", "valueString": "Experience the ultimate racing performance with the Sprint Racer Kayak, meticulously crafted for competitive racers. Built with carbon fiber for exceptional durability, this kayak ensures a lightweight yet sturdy ride. Featuring an 18 ft length and a sleek 20-inch width, it is designed for high-speed racing with low stability for maximum performance. Available in striking blue and yellow colors, it comes equipped with an adjustable seat and spray skirt for your comfort and convenience. Certified race-ready and designed with low emissions manufacturing, this kayak supports both your competitive spirit and environmental consciousness. Its portability is enhanced with shoulder carry straps, and safety is a top priority with an emergency quick-release system. Make waves with the Sprint Racer Kayak!TKKP_027B"}, {"key": "ec_category", "valueString": "Slalom Kayaks"}, {"key": "clickUri", "valueString": "/products/tkkp_027b"}, {"key": "resultType", "valueString": "product"}, {"key": "queryPinned", "valueString": "false"}, {"key": "ec_shortdesc", "valueString": "Experience the ultimate racing performance with the Sprint Racer Kayak, meticulously crafted for competitive racers. Built with carbon fiber for exceptional durability, this kayak ensures a lightweight yet sturdy ride. Featuring an 18 ft length and a sleek 20-inch width, it is designed for high-speed racing with low stability for maximum performance. Available in striking blue and yellow colors, it comes equipped with an adjustable seat and spray skirt for your comfort and convenience. Certified race-ready and designed with low emissions manufacturing, this kayak supports both your competitive spirit and environmental consciousness. Its portability is enhanced with shoulder carry straps, and safety is a top priority with an emergency quick-release system. Make waves with the Sprint Racer Kayak!TKKP_027B"}, {"key": "ec_in_stock", "valueString": "true"}, {"key": "ec_item_group_id", "valueString": "9934401110290"}, {"key": "ec_color", "valueString": "Blue"}, {"key": "permanentid", "valueString": "gid://shopify/ProductVariant/50675199082770"}, {"key": "excerpt", "valueString": "... ultimate racing performance with the Sprint Racer Kayak, meticulously crafted for competitive racers. ... carbon fiber for exceptional durability, this kayak ensures a lightweight yet sturdy ..."}, {"key": "totalNumberOfChildren", "valueNumber": 2.0}]}, {"key": "5", "valueMap": [{"key": "ec_name", "valueString": "Streak Racing Kayak - White"}, {"key": "ec_brand", "valueString": "Vajda Group"}, {"key": "ec_price", "valueNumber": 1799.99}, {"key": "ec_promo_price", "valueNumber": 1799.99}, {"key": "ec_image", "valueString": "https://cdn.shopify.com/s/files/1/0910/6502/4786/files/52db0b60c6f1_top_left.webp?v=1766164980"}, {"key": "ec_product_id", "valueString": "gid://shopify/ProductVariant/50675197542674"}, {"key": "ec_description", "valueString": "Experience the thrill of high-speed water racing with the Streak Racing Kayak. Designed for recreational athletes and competitive events, this kayak offers a perfect blend of durability and performance. Constructed from premium fiberglass, it is both lightweight and waterproof, ensuring long-lasting use in various water conditions. Available in striking white and red colors, the Streak Racing Kayak includes ergonomic footrests and a repair kit for your convenience. With ISO and T\u00dcV certifications, a reinforced hull for enhanced safety, and shoulder carry straps for easy portability, this kayak is built for serious racers. Its high-speed design and moderate stability make it ideal for competitive environments, while the lifetime hull warranty provides peace of mind. Paddle towards victory with the Streak Racing Kayak.VGKP_43B9"}, {"key": "ec_category", "valueString": "Slalom Kayaks"}, {"key": "clickUri", "valueString": "/products/vgkp_43b9"}, {"key": "resultType", "valueString": "product"}, {"key": "queryPinned", "valueString": "false"}, {"key": "ec_shortdesc", "valueString": "Experience the thrill of high-speed water racing with the Streak Racing Kayak. Designed for recreational athletes and competitive events, this kayak offers a perfect blend of durability and performance. Constructed from premium fiberglass, it is both lightweight and waterproof, ensuring long-lasting use in various water conditions. Available in striking white and red colors, the Streak Racing Kayak includes ergonomic footrests and a repair kit for your convenience. With ISO and T\u00dcV certifications, a reinforced hull for enhanced safety, and shoulder carry straps for easy portability, this kayak is built for serious racers. Its high-speed design and moderate stability make it ideal for competitive environments, while the lifetime hull warranty provides peace of mind. Paddle towards victory with the Streak Racing Kayak.VGKP_43B9"}, {"key": "ec_in_stock", "valueString": 